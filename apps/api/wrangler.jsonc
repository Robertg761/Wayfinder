{
  "$schema": "./node_modules/wrangler/config-schema.json",
  // Secrets (set with `wrangler secret put`):
  // - GITHUB_TOKEN: must be a fine-grained PAT limited to PUBLIC READ access.
  //   Classic tokens with the "repo" scope are refused at runtime because this
  //   public Worker would expose private-repository reads. See SECURITY.md.
  // - OPENAI_API_KEY: enables GPT-5.6 Luna synthesis.
  // - HEALTH_DIAGNOSTICS_KEY: optional; unlocks budget/deployment details on /health.
  "name": "wayfinder-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-13",
  "observability": {
    "enabled": true
  },
  "version_metadata": {
    "binding": "CF_VERSION_METADATA"
  },
  "vars": {
    "MODEL_BUDGET_USD": "100"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "MODEL_BUDGET",
        "class_name": "ModelBudget"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ModelBudget"]
    }
  ],
  "ratelimits": [
    {
      "name": "MODEL_RATE_LIMITER",
      "namespace_id": "3022301",
      "simple": {
        "limit": 10,
        "period": 60
      }
    },
    {
      "name": "API_RATE_LIMITER",
      "namespace_id": "3022302",
      "simple": {
        "limit": 60,
        "period": 60
      }
    }
  ],
  // Deploy experiments with `wrangler deploy --env dev`: a separate Worker
  // name, budget ledger namespace, and rate-limit namespaces, so a staging
  // push can never touch the production ledger or its rate-limit counters.
  // The top-level (no --env) configuration remains production. The dev
  // namespace ids below are verified unique in this account (2026-07-23:
  // only wayfinder-api binds rate limiters, using 3022301/3022302).
  "env": {
    "dev": {
      "name": "wayfinder-api-dev",
      "vars": {
        "MODEL_BUDGET_USD": "5"
      },
      "durable_objects": {
        "bindings": [
          {
            "name": "MODEL_BUDGET",
            "class_name": "ModelBudget"
          }
        ]
      },
      "migrations": [
        {
          "tag": "v1",
          "new_sqlite_classes": ["ModelBudget"]
        }
      ],
      "ratelimits": [
        {
          "name": "MODEL_RATE_LIMITER",
          "namespace_id": "3022311",
          "simple": {
            "limit": 10,
            "period": 60
          }
        },
        {
          "name": "API_RATE_LIMITER",
          "namespace_id": "3022312",
          "simple": {
            "limit": 60,
            "period": 60
          }
        }
      ]
    }
  }
}
